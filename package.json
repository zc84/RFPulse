{
  "name": "rfpulse",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run dev:frontend\"",
    "dev:frontend": "vite --host 0.0.0.0 --port 5001",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "dev:full": "concurrently \"npm run server:dev\" \"npm run dev:frontend\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "openai": "^6.44.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  }
}
